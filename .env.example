# === Server-side (used by Express dev server + Vercel Serverless Functions) ===

# Gemini API key — never exposed to the browser
GEMINI_API_KEY=your-gemini-api-key

# PostgreSQL connection string (Drizzle ORM)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# CORS origin for the API (defaults to http://localhost:5173 in dev)
FRONTEND_ORIGIN=http://localhost:5173

# Gemini model override (defaults to gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# === Client-side (VITE_ prefix = embedded in browser bundle at build time) ===

# Google OAuth Client ID for Google Slides export
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
